# Firebase Configuration
# Get these values from your Firebase project settings (Project Settings > Your apps > Web app)
# These must be prefixed with NEXT_PUBLIC_ to be accessible in the browser

# Firebase API Key
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase Authentication Domain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here

# Firebase Project ID (REQUIRED)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Storage Bucket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here

# Firebase Messaging Sender ID (REQUIRED)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here

# Firebase App ID (REQUIRED)
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Firebase Cloud Messaging VAPID Key (for push notifications)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Socket.IO Server URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
