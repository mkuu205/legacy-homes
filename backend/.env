
DATABASE_URL="postgresql://user:password@localhost:5432/database?schema=public"

# Auth
JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="1d"
REFRESH_TOKEN_SECRET="your_refresh_token_secret"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Tuma Payments (M-Pesa STK Push)
TUMA_API_URL="https://api.tuma.co.ke"
TUMA_AUTH_URL="https://api.tuma.co.ke/auth/token"
TUMA_BUSINESS_EMAIL="Legackhomesk@gmail.com"
TUMA_API_KEY="YOUR_TUMA_API_KEY"
TUMA_CALLBACK_URL="https://legacy-homes.onrender.com/api/payments/tuma/callback"

# Pesapal Payments (Card Payment)
PESAPAL_API_URL="https://api.pesapal.com/api/v3"
PESAPAL_CONSUMER_KEY="YOUR_PESAPAL_CONSUMER_KEY"
PESAPAL_CONSUMER_SECRET="YOUR_PESAPAL_CONSUMER_SECRET"
PESAPAL_IPN_URL="https://legacy-homes.onrender.com/api/payments/pesapal/ipn"

# SMS (TalkSasa)
TALKSASA_API_KEY="your_talksasa_api_key"
TALKSASA_SENDER_ID="your_sender_id"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
FROM_EMAIL="Legackhomesk@gmail.com"

# Server
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
