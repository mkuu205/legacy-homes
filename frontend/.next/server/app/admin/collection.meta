{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/collection/layout,_N_T_/admin/collection/page,_N_T_/admin/collection"
  },
  "segmentPaths": [
    "/_tree",
