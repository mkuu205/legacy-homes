// Legacy Homes Water Billing System - Prisma Schema
// PostgreSQL database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  BILLING_OFFICER
  SUPPORT_AGENT
  NOTIFICATION_MANAGER
  READ_ONLY_MANAGER
  RESIDENT
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HouseStatus {
  OCCUPIED
  VACANT
  UNDER_CONSTRUCTION
  SUSPENDED
  MAINTENANCE
}

enum MeterStatus {
  ACTIVE
  FAULTY
  REPLACED
}

enum BillStatus {
  PAID
  PARTIAL
  UNPAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

enum PaymentReconciliationStatus {
  PENDING
  RECONCILED
  MISMATCH
  ORPHANED
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketCategory {
  BILLING
  PAYMENT
  METER
  TECHNICAL
  COMPLAINT
  ACCOUNT
}

enum NotificationType {
  MAINTENANCE
  WATER_OUTAGE
  BILLING_REMINDER
  PAYMENT_REMINDER
  EMERGENCY
  ESTATE_COMMUNICATION
  PAYMENT_CONFIRMATION
  BILLING_ALERT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  READ
}

// ─────────────────────────────────────────────
// HOUSES
// ─────────────────────────────────────────────

model House {
  id               String      @id @default(uuid())
  houseNumber      String      @unique
  occupancyStatus  HouseStatus @default(UNDER_CONSTRUCTION)
  creationDate     DateTime    @default(now())
  notes            String?
  isLocked         Boolean     @default(false) // For billing cycle locking
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  resident         User?       @relation("HouseToResident")
  meter            Meter?      @relation("HouseToMeter")
  bills            Bill[]

  @@map("houses")
}

// ─────────────────────────────────────────────
// USERS (Admins + Residents share this table)
// ─────────────────────────────────────────────

model User {
  id                String             @id @default(uuid())
  fullName          String
  email             String             @unique
  phone             String             @unique
  passwordHash      String
  role              Role               @default(RESIDENT)
  accountStatus     AccountStatus      @default(INACTIVE)
  registrationStatus RegistrationStatus @default(PENDING)
  profilePicture    String?
  nationalId        String?
  accountNumber     String             @unique
  houseId           String?            @unique // Foreign key for House
  emailVerified     Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  otpCodes          OtpCode[]
  refreshTokens     RefreshToken[]
  assignedHouse     House?             @relation("HouseToResident", fields: [houseId], references: [id])
  bills             Bill[]
  payments          Payment[]
  tickets           Ticket[]
  ticketReplies     TicketReply[]
  notifications     UserNotification[]
  auditLogs         AuditLog[]
  meterReadings     MeterReading[]
  assignedTickets   Ticket[]           @relation("AssignedTickets")

  @@map("users")
}

// ─────────────────────────────────────────────
// OTP CODES
// ─────────────────────────────────────────────

model OtpCode {
  id          String   @id @default(uuid())
  userId      String
  otpHash     String
  expiresAt   DateTime
  attempts    Int      @default(0)
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

// ─────────────────────────────────────────────
// REFRESH TOKENS
// ─────────────────────────────────────────────

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// METERS
// ─────────────────────────────────────────────

model Meter {
  id               String      @id @default(uuid())
  meterNumber      String      @unique
  meterSerial      String      @unique
  houseId          String      @unique // Foreign key for House
  installationDate DateTime
  previousReading  Float       @default(0)
  currentReading   Float       @default(0)
  status           MeterStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  house            House       @relation("HouseToMeter", fields: [houseId], references: [id])
  readings         MeterReading[]
  bills            Bill[]

  @@map("meters")
}

// ─────────────────────────────────────────────
// METER READINGS
// ─────────────────────────────────────────────

model MeterReading {
  id              String   @id @default(uuid())
  meterId         String
  readBy          String
  billingMonth    String
  previousReading Float
  currentReading  Float
  unitsConsumed   Float
  photoUrl        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meter           Meter    @relation(fields: [meterId], references: [id])
  reader          User     @relation(fields: [readBy], references: [id])
  billId          String?  @unique // Foreign key for Bill
  bill            Bill?    @relation("MeterReadingToBill")

  @@unique([meterId, billingMonth])
  @@map("meter_readings")
}

// ─────────────────────────────────────────────
// BILLS
// ─────────────────────────────────────────────

model Bill {
  id              String     @id @default(uuid())
  billNumber      String     @unique
  residentId      String
  houseId         String
  meterId         String
  readingId       String?    @unique // Foreign key for MeterReading
  billingMonth    String
  previousReading Float
  currentReading  Float
  unitsConsumed   Float
  unitRate        Float      @default(250)
  totalAmount     Float
  amountPaid      Float      @default(0)
  balance         Float
  dueDate         DateTime
  status          BillStatus @default(UNPAID)
  isLocked        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  resident        User          @relation(fields: [residentId], references: [id])
  house           House         @relation(fields: [houseId], references: [id])
  meter           Meter         @relation(fields: [meterId], references: [id])
  reading         MeterReading? @relation("MeterReadingToBill", fields: [readingId], references: [id])
  payments        Payment[]

  @@map("bills")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id                String                    @id @default(uuid())
  paymentId         String                    @unique
  billId            String
  residentId        String
  amount            Float
  phoneNumber       String
  mpesaReceiptCode  String?
  payHeroReference  String? // Deprecated after PayHero removal
  merchantRequestId String?
  checkoutRequestId String?
  provider          String                    @default("TUMA") // Defaults to TUMA for new, but existing will be PAYHERO
  callbackPayload   Json?
  verificationTimestamp DateTime?
  status            PaymentStatus             @default(PENDING)
  reconciliationStatus PaymentReconciliationStatus @default(PENDING)
  failureReason     String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  bill              Bill                      @relation(fields: [billId], references: [id])
  resident          User                      @relation(fields: [residentId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// SUPPORT TICKETS
// ─────────────────────────────────────────────

model Ticket {
  id          String         @id @default(uuid())
  ticketId    String         @unique
  residentId  String
  assignedTo  String?
  subject     String
  description String
  category    TicketCategory
  status      TicketStatus   @default(OPEN)
  attachments String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  resident    User           @relation(fields: [residentId], references: [id])
  assignee    User?          @relation("AssignedTickets", fields: [assignedTo], references: [id])
  replies     TicketReply[]

  @@map("tickets")
}

model TicketReply {
  id          String   @id @default(uuid())
  ticketId    String
  userId      String
  message     String
  attachments String[]
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@map("ticket_replies")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id          String                @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  channels    NotificationChannel[]
  sentBy      String?
  targetAll   Boolean               @default(false)
  targetGroup String?
  createdAt   DateTime              @default(now())

  userNotifications UserNotification[]

  @@map("notifications")
}

model UserNotification {
  id             String             @id @default(uuid())
  notificationId String
  userId         String
  channel        NotificationChannel
  status         NotificationStatus @default(PENDING)
  readAt         DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime           @default(now())

  notification   Notification       @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  resource    String
  resourceId  String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// SYSTEM SETTINGS
// ─────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model CallbackAudit {
  id          String   @id @default(uuid())
  payload     Json
  receivedAt  DateTime @default(now())
  processed   Boolean  @default(false)
  paymentId   String?
  provider    String   @default("TUMA")

  @@map("callback_audits")
}
